                  "id": "footer-company-list",
                  "elType": "widget",
                  "widgetType": "icon-list",
                  "settings": {
                    "icon_list": [
                      {"text": "¿Cómo lo hacemos?", "link": {"url": "#"}},
                      {"text": "¿Quiénes somos?", "link": {"url": "#"}},
