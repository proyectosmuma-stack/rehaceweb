                  "id": "footer-services-list",
                  "elType": "widget",
                  "widgetType": "icon-list",
                  "settings": {
                    "icon_list": [
                      {"text": "Ictus y Daño Cerebral", "link": {"url": "#"}},
                      {"text": "Parkinson", "link": {"url": "#"}},
                      {"text": "Alzheimer y Demencias", "link": {"url": "#"}},
                      {"text": "Esclerosis Múltiple", "link": {"url": "#"}},
                      {"text": "TEA y TDAH (Niños)", "link": {"url": "#"}}
